# ==========================================
# 🤖 PERSONAL RESEARCH AGENT - CONFIGURATION
# ==========================================

# ------------------------------------------
# [1] API KEYS & AUTHENTICATION
# ------------------------------------------
# Google Gemini API Key (Used for LLM reasoning, content filtering, and analyzing)
# Get yours from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Tavily Search API Key (Used for high-quality web searching and scraping)
# Get yours from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# ------------------------------------------
# [2] TELEGRAM BOT SETTINGS
# ------------------------------------------
# Telegram Bot Token (Provided by BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Personal Telegram Chat ID (Required for receiving the scheduled daily digests)
# Note: The bot will print this ID to you when you send the /start command.
TELEGRAM_ADMIN_ID=your_telegram_chat_id_here

# Timezone used for the Cron Job (Daily 7:00 AM updates)
TIMEZONE=Asia/Ho_Chi_Minh

# ------------------------------------------
# [3] AI PIPELINE & GRAPH TUNING
# ------------------------------------------
# Base number of URLs the Scraper fetches from Tavily in a single search round.
# (This automatically escalates during retry loops to dig deeper).
MAX_SEARCH_RESULTS=5

# The minimum number of HIGH-QUALITY articles the Filter Node must approve.
# If the approved count is below this, the system triggers a Feedback Loop to search again.
MIN_FILTERED_ARTICLES=2
